{% extends 'base.html.twig' %}

{% block title %}Mon Compte{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto px-4 py-12">
    <h1 class="font-bebas text-4xl tracking-widest text-orange-500 mb-8">{{ 'account.title'|trans|upper }}</h1>

    <div class="bg-gray-900 border border-orange-600/20 rounded-lg p-6 space-y-4">

        <div class="flex justify-center mb-4">
            {% if app.user.imageName %}
                <img src="{{ vich_uploader_asset(app.user, 'imageFile')|imagine_filter('avatar_thumbnail') }}"
                    alt="Profile"
                    class="rounded-full w-32 h-32 object-cover border border-orange-600/30">
            {% else %}
                <div class="rounded-full w-32 h-32 bg-gray-800 border border-orange-600/30 flex items-center justify-center text-gray-500 text-sm">
                    {{ 'account.noImage'|trans }}
                </div>
            {% endif %}
        </div>

        <div>
            <span class="text-gray-400 text-sm">{{ 'account.firstname'|trans }}</span>
            <p class="text-white text-lg">{{ app.user.firstname }}</p>
        </div>
        <div>
            <span class="text-gray-400 text-sm">{{ 'account.lastname'|trans }}</span>
            <p class="text-white text-lg">{{ app.user.lastname }}</p>
        </div>
        <div>
            <span class="text-gray-400 text-sm">{{ 'account.email'|trans }}</span>
            <p class="text-white text-lg">{{ app.user.email }}</p>
        </div>

        <div class="pt-4">
            <a href="{{ path('app_account_edit') }}"
            class="bg-orange-500 hover:bg-orange-600 text-white font-bebas tracking-widest px-6 py-3 rounded uppercase inline-block">
                {{ 'account.editButton'|trans }}
            </a>
        </div>
    </div>
</div>
{% endblock %}