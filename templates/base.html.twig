<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Basketball{% endblock %}</title>
        <link rel="stylesheet" href="{{ asset('style/app.css') }}">
        <script src="https://cdn.tailwindcss.com"></script>

        <style>
            @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;600;700&display=swap');
            body { font-family: 'Inter', sans-serif; }
            .font-bebas { font-family: 'Bebas Neue', cursive; }
            .gradient-orange { background: linear-gradient(135deg, #ea580c 0%, #dc2626 100%); }
            .card-hover { transition: all 0.3s ease; }
            .card-hover:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(234,88,12,0.3); }
            .nav-link { position: relative; }
            .nav-link::after { content: ''; position: absolute; bottom: -4px; left: 0; width: 0; height: 2px; background: #fb923c; transition: width 0.3s; }
            .nav-link:hover::after { width: 100%; }
            .glow { box-shadow: 0 0 30px rgba(234,88,12,0.4); }

            ul[id$="_errors"] li,
            li[id*="_error"] {
                color: #ef4444;
                list-style: none;
            }
        </style>
    </head>
    <body class="bg-gray-100 min-h-screen flex flex-col min-h-screen">

        {{ include('/layouts/partials/_nav.html.twig') }}

        <div class="max-w-7xl mx-auto px-4 pt-4">
            {% for flash_success in app.flashes('success') %}
                <div class="bg-green-600 text-white px-4 py-3 rounded mb-3">{{ flash_success }}</div>
            {% endfor %}
            {% for flash_error in app.flashes('error') %}
                <div class="bg-red-600 text-white px-4 py-3 rounded mb-3">{{ flash_error }}</div>
            {% endfor %}
            {% for flash_info in app.flashes('info') %}
                <div class="bg-blue-600 text-white px-4 py-3 rounded mb-3">{{ flash_info }}</div>
            {% endfor %}
        </div>

        <main class="flex-grow">
            {% block body %}{% endblock %}
        </main>

        {{ include('/layouts/partials/_footer.html.twig') }}

    </body>
</html>