<header class="fixed top-0 left-0 right-0 z-50 bg-black backdrop-blur-md border-b border-orange-600/20">
    <nav class="max-w-7xl mx-auto px-6 sm:px-6 py-6 grid grid-cols-3 items-center">

        <a href="{{ path('app_home') }}" class="flex items-center gap-2 group justify-self-start">
            <span class="text-3xl">🏀</span>
            <span class="font-bebas text-2xl tracking-widest text-orange-500 group-hover:text-orange-400 transition-colors">
                BASKETBALL
            </span>
        </a>

        <ul class="hidden md:flex items-center gap-8 justify-self-center">
            <li>
                <a href="{{ path('app_home') }}" 
                    class="font-medium transition-colors pb-1
                    {{ app.current_route == 'app_home' 
                        ? 'text-orange-400 border-b-2 border-orange-400' 
                        : 'text-gray-300 hover:text-white' }}">
                    {{ 'navBar.home'|trans }}
                </a>
            </li>
            <li>
                <a href="{{ path('app_player') }}" 
                    class="font-medium transition-colors pb-1
                    {{ app.current_route starts with 'app_player' 
                        ? 'text-orange-400 border-b-2 border-orange-400' 
                        : 'text-gray-300 hover:text-white' }}">
                    {{ 'navBar.players'|trans }}
                </a>
            </li>
            {% if app.user %}
                <li>
                    <a href="{{ path('app_player_create') }}" 
                        class="font-medium transition-colors pb-1
                        {{ app.current_route == 'app_player_create' 
                            ? 'text-orange-400 border-b-2 border-orange-400' 
                            : 'text-gray-300 hover:text-white' }}">
                        {{ 'navBar.addPlayer'|trans }}
                    </a>
                </li>
            {% endif %}
        </ul>

        <div class="hidden md:flex items-center gap-6 justify-self-end">
            {% if app.user %}
                <a href="{{ path('app_account') }}" 
                    class="font-medium transition-colors pb-1
                    {{ app.current_route == 'app_account' 
                        ? 'text-orange-400 border-b-2 border-orange-400' 
                        : 'text-gray-300 hover:text-white' }}">
                    {{ 'navBar.account'|trans }}
                </a>
                <a href="{{ path('app_logout') }}" 
                    class="font-medium text-gray-300 hover:text-white transition-colors pb-1">
                    {{ 'navBar.logout'|trans }}
                </a>
            {% else %}
                <a href="{{ path('app_register') }}" 
                    class="font-medium transition-colors pb-1
                    {{ app.current_route == 'app_register' 
                        ? 'text-orange-400 border-b-2 border-orange-400' 
                        : 'text-gray-300 hover:text-white' }}">
                    {{ 'navBar.register'|trans }}
                </a>
                <a href="{{ path('app_login') }}" 
                    class="font-medium transition-colors pb-1
                    {{ app.current_route == 'app_login' 
                        ? 'text-orange-400 border-b-2 border-orange-400' 
                        : 'text-gray-300 hover:text-white' }}">
                    {{ 'navBar.login'|trans }}
                </a>
            {% endif %}

            <!--buttone lingue-->
            <div class="relative group">
                <button class="flex items-center gap-1.5 font-medium text-gray-300 hover:text-white transition-colors pb-1 uppercase text-sm">
                    <svg class="w-4 h-4 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.6 9h16.8M3.6 15h16.8M11.5 3a17 17 0 0 0 0 18M12.5 3a17 17 0 0 1 0 18"/>
                        <circle cx="12" cy="12" r="9" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
                    </svg>
                    {{ app.request.locale }}
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                </button>
                <div class="absolute right-0 mt-2 w-24 bg-gray-900 border border-orange-600/20 rounded-lg shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50">
                    <a href="{{ path('app_locale_switch', {locale: 'fr'}) }}" class="block px-4 py-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-orange-400 rounded-t-lg">
                        Français
                    </a>
                    <a href="{{ path('app_locale_switch', {locale: 'it'}) }}" class="block px-4 py-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-orange-400 rounded-b-lg">
                        Italiano
                    </a>
                </div>
            </div>
        </div>

        <!-- Menu hamburger mobile -->
        <button id="menu-btn" class="md:hidden text-white focus:outline-none justify-self-end">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
        </button>
    </nav>

    <!-- Menu mobile -->
    <div id="mobile-menu" class="hidden md:hidden bg-gray-900 border-t border-orange-600/20 px-4 py-4 space-y-3">
        <a href="{{ path('app_home') }}" 
            class="block py-2 transition-colors
            {{ app.current_route == 'app_home' 
                ? 'text-orange-400' : 'text-gray-300 hover:text-orange-400' }}">
            {{ 'navBar.home'|trans }}
        </a>
        <a href="{{ path('app_player') }}" 
            class="block py-2 transition-colors
            {{ app.current_route starts with 'app_player' 
                ? 'text-orange-400' : 'text-gray-300 hover:text-orange-400' }}">
            {{ 'navBar.players'|trans }}
        </a>
        {% if app.user %}
            <a href="{{ path('app_player_create') }}" 
                class="block py-2 transition-colors
                {{ app.current_route == 'app_player_create' 
                    ? 'text-orange-400' : 'text-gray-300 hover:text-orange-400' }}">
                {{ 'navBar.addPlayer'|trans }}
            </a>
            <a href="{{ path('app_account') }}" 
                class="block py-2 transition-colors
                {{ app.current_route == 'app_account' 
                    ? 'text-orange-400' : 'text-gray-300 hover:text-orange-400' }}">
                {{ 'navBar.account'|trans }}
            </a>
            <a href="{{ path('app_logout') }}" 
                class="block py-2 text-gray-300 hover:text-orange-400 transition-colors">
                {{ 'navBar.logout'|trans }}
            </a>
        {% else %}
            <a href="{{ path('app_register') }}" 
                class="block py-2 transition-colors
                {{ app.current_route == 'app_register' 
                    ? 'text-orange-400' : 'text-gray-300 hover:text-orange-400' }}">
                {{ 'navBar.register'|trans }}
            </a>
            <a href="{{ path('app_login') }}" 
                class="block py-2 transition-colors
                {{ app.current_route == 'app_login' 
                    ? 'text-orange-400' : 'text-gray-300 hover:text-orange-400' }}">
                {{ 'navBar.login'|trans }}
            </a>
        {% endif %}

        <div class="border-t border-orange-600/20 pt-3 mt-3 flex gap-4">
            <svg class="w-4 h-4 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.6 9h16.8M3.6 15h16.8M11.5 3a17 17 0 0 0 0 18M12.5 3a17 17 0 0 1 0 18"/>
                <circle cx="12" cy="12" r="9" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
            </svg>
            <a href="{{ path('app_locale_switch', {locale: 'fr'}) }}" class="text-gray-300 hover:text-orange-400 text-sm">Français</a>
            <a href="{{ path('app_locale_switch', {locale: 'it'}) }}" class="text-gray-300 hover:text-orange-400 text-sm">Italiano</a>
        </div>
    </div>
</header>

<!-- header fixe -->
<div class="h-16"></div>

<script>
    document.getElementById('menu-btn').addEventListener('click', function() {
        document.getElementById('mobile-menu').classList.toggle('hidden');
    });
</script>