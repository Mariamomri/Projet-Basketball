{% extends 'base.html.twig' %}

{% block title %}Password Reset Email Sent{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-4 py-12">
    <div class="bg-gray-900 border border-orange-600/20 rounded-lg p-6">
        <p class="text-gray-300 leading-relaxed mb-4">
            {{ 'resetPassword.checkEmailText'|trans }}
            {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
        </p>
        <p class="text-gray-400 text-sm">
            {{ 'resetPassword.checkEmailSpam'|trans }}
            <a href="{{ path('app_forgot_password_request') }}" class="text-orange-400 hover:text-orange-300 underline">
                {{ 'resetPassword.checkEmailRetry'|trans }}
            </a>.
        </p>
    </div>
</div>
{% endblock %}