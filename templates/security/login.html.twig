{% extends 'base.html.twig' %}

{% block title %}Log in!{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-4 py-12">
    <h1 class="font-bebas text-4xl tracking-widest text-orange-500 mb-8">SE CONNECTER</h1>

    {% if app.user %}
        <div class="bg-gray-900 border border-orange-600/20 rounded-lg p-6 text-gray-300">
            You are logged in as {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}" class="text-orange-400 hover:text-orange-300 underline">Logout</a>
        </div>
    {% else %}
        <div class="bg-gray-900 border border-orange-600/20 rounded-lg p-6">
            <form method="post" class="space-y-4">
                {% if error %}
                    <div class="bg-red-600 text-white px-4 py-3 rounded">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <div>
                    <label for="username" class="text-gray-300 text-sm block mb-1">Email</label>
                    <input type="email" value="{{ last_username }}" name="_username" id="username"
                        class="w-full bg-gray-800 text-white border border-gray-700 rounded px-3 py-2"
                        autocomplete="email" required autofocus>
                </div>

                <div>
                    <label for="password" class="text-gray-300 text-sm block mb-1">Password</label>
                    <input type="password" name="_password" id="password"
                        class="w-full bg-gray-800 text-white border border-gray-700 rounded px-3 py-2"
                        autocomplete="current-password" required>
                </div>

                <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                <button class="w-full bg-orange-600 hover:bg-orange-500 text-white font-medium py-2 rounded transition-colors" type="submit">
                    Sign in
                </button>
            </form>

            <div class="mt-4 text-center">
                <a href="{{ path('app_register') }}" class="text-gray-400 hover:text-orange-400 text-sm transition-colors">
                    Create an account
                </a>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}